{
  "name": "tokn",
  "version": "0.1.0",
  "description": "Tray-first token usage monitor for Codex and Cursor on Windows.",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "check": "tsc -p tsconfig.json --noEmit",
    "start": "electron .",
    "preview": "vite preview",
    "report": "tsx src/index.ts report",
    "cursor-auth": "tsx src/index.ts cursor-auth"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "csv-parse": "^5.5.6",
    "luxon": "^3.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "electron": "^38.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.11",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
